package ohos_app_cangjie_entry

internal import std.unittest.*
import std.unittest.testmacro.*
internal import kit.UniversalKeystoreKit.*
import std.unittest.testmacro.*
import std.unittest.*
import std.unittest.common.*
import std.unittest.testmacro.*
import ohos.base.*

/**
 * жөӢиҜ•ohos.security.huksжЁЎеқ—зҡ„importKeyItemеҠҹиғҪ
 */
@Test
class Test_Huks_KeyItem_Import_Add {
    // жөӢиҜ•з”Ёзҡ„еҜҶй’ҘеҲ«еҗҚ
    private static const TEST_KEY_ALIAS: String = "test_key_alias"
    private static const EMPTY_KEY_ALIAS: String = ""
    private static const ONE_CHAR_KEY_ALIAS: String = "a"
    private static const MAX_LENGTH_KEY_ALIAS: String = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" // жңҖеӨ§й•ҝеәҰ128
    private static const LONG_KEY_ALIAS: String = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" // и¶…еҮәжңҖеӨ§й•ҝеәҰ128 (129дёӘa)

    /**
     * жөӢиҜ•importKeyItem API - жңүж•Ҳзӯүд»·зұ»пјҡжңүж•Ҳзҡ„еҜҶй’ҘеҲ«еҗҚе’ҢйҖүйЎ№
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_keyAlias_valid() {
        // зЎ®дҝқжөӢиҜ•еүҚеҜҶй’ҘдёҚеӯҳеңЁ
        try {
            deleteKeyItem(TEST_KEY_ALIAS, HuksOptions())
        } catch (_) {
            // еҝҪз•ҘеҲ йҷӨдёҚеӯҳеңЁеҜҶй’Ҙзҡ„ејӮеёё
        }

        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        // еҜје…ҘеҜҶй’Ҙ
        importKeyItem(TEST_KEY_ALIAS, options)

        // йӘҢиҜҒеҜҶй’ҘеӯҳеңЁ
        let exists = hasKeyItem(TEST_KEY_ALIAS, HuksOptions())
        @Expect(exists)

        // жё…зҗҶпјҡеҲ йҷӨеҜје…Ҙзҡ„еҜҶй’Ҙ
        deleteKeyItem(TEST_KEY_ALIAS, HuksOptions())
    }

    /**
     * жөӢиҜ•importKeyItem API - ж— ж•Ҳзӯүд»·зұ»пјҡз©әеҜҶй’ҘеҲ«еҗҚ
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_keyAlias_empty() {
        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        try {
            importKeyItem(EMPTY_KEY_ALIAS, options)
            @Expect(false) // дёҚеә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            // йў„жңҹжҠӣеҮәеҸӮж•°ејӮеёё
            @Expect(true)
        }
    }

    /**
     * жөӢиҜ•importKeyItem API - ж— ж•Ҳзӯүд»·зұ»пјҡз©әproperties
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_options_empty_properties() {
        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [],
            inData: keyData
        )

        try {
            importKeyItem(TEST_KEY_ALIAS, options)
            @Expect(false) // дёҚеә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            // йў„жңҹжҠӣеҮәеҸӮж•°ејӮеёё
            @Expect(true)
        }
    }

    /**
     * жөӢиҜ•importKeyItem API - ж— ж•Ҳзӯүд»·зұ»пјҡз©әinData
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_options_empty_indata() {
        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: []
        )

        try {
            importKeyItem(TEST_KEY_ALIAS, options)
            @Expect(false) // дёҚеә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            // йў„жңҹжҠӣеҮәеҸӮж•°ејӮеёё
            @Expect(true)
        }
    }

    /**
     * жөӢиҜ•importKeyItem API - ж— ж•Ҳзӯүд»·зұ»пјҡзјәе°‘з®—жі•еҸӮж•°
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_options_missing_algorithm() {
        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        try {
            importKeyItem(TEST_KEY_ALIAS, options)
            @Expect(false) // дёҚеә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            // йў„жңҹжҠӣеҮәеҸӮж•°ејӮеёё
            @Expect(true)
        }
    }

    /**
     * жөӢиҜ•importKeyItem API - иҫ№з•ҢеҖјпјҡй•ҝеәҰдёә1зҡ„еҜҶй’ҘеҲ«еҗҚ
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_keyAlias_length_1() {
        // зЎ®дҝқжөӢиҜ•еүҚеҜҶй’ҘдёҚеӯҳеңЁ
        try {
            deleteKeyItem(ONE_CHAR_KEY_ALIAS, HuksOptions())
        } catch (_) {
            // еҝҪз•ҘеҲ йҷӨдёҚеӯҳеңЁеҜҶй’Ҙзҡ„ејӮеёё
        }

        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        // еҜје…ҘеҜҶй’Ҙ
        importKeyItem(ONE_CHAR_KEY_ALIAS, options)

        // йӘҢиҜҒеҜҶй’ҘеӯҳеңЁ
        let exists = hasKeyItem(ONE_CHAR_KEY_ALIAS, HuksOptions())
        @Expect(exists)

        // жё…зҗҶпјҡеҲ йҷӨеҜје…Ҙзҡ„еҜҶй’Ҙ
        deleteKeyItem(ONE_CHAR_KEY_ALIAS, HuksOptions())
    }

    /**
     * жөӢиҜ•importKeyItem API - иҫ№з•ҢеҖјпјҡжңҖеӨ§й•ҝеәҰзҡ„еҜҶй’ҘеҲ«еҗҚ
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_keyAlias_length_128() {
        // зЎ®дҝқжөӢиҜ•еүҚеҜҶй’ҘдёҚеӯҳеңЁ
        try {
            deleteKeyItem(MAX_LENGTH_KEY_ALIAS, HuksOptions())
        } catch (_) {
            // еҝҪз•ҘеҲ йҷӨдёҚеӯҳеңЁеҜҶй’Ҙзҡ„ејӮеёё
        }

        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        // еҜје…ҘеҜҶй’Ҙ
        importKeyItem(MAX_LENGTH_KEY_ALIAS, options)

        // йӘҢиҜҒеҜҶй’ҘеӯҳеңЁ
        let exists = hasKeyItem(MAX_LENGTH_KEY_ALIAS, HuksOptions())
        @Expect(exists)

        // жё…зҗҶпјҡеҲ йҷӨеҜје…Ҙзҡ„еҜҶй’Ҙ
        deleteKeyItem(MAX_LENGTH_KEY_ALIAS, HuksOptions())
    }

    /**
     * жөӢиҜ•importKeyItem API - иҫ№з•ҢеҖјпјҡи¶…еҮәжңҖеӨ§й•ҝеәҰзҡ„еҜҶй’ҘеҲ«еҗҚ
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_keyAlias_length_129() {
        // еҮҶеӨҮиҰҒеҜје…Ҙзҡ„еҜҶй’Ҙж•°жҚ®
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })

        // еҮҶеӨҮеҜје…ҘйҖүйЎ№
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )

        try {
            importKeyItem(LONG_KEY_ALIAS, options)
            @Expect(false) // дёҚеә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            // йў„жңҹжҠӣеҮәеҸӮж•°ејӮеёё
            @Expect(true)
        }
    }

    /**
     * жөӢиҜ•importKeyItem API - жӯЈеёёеӨ„зҗҶпјҡеҗҢеҗҚеҜҶй’Ҙе·ІеӯҳеңЁ
     */
    @TestCase
    @Tag[APILevel22, TestLevel0]
    func test_importKeyItem_exception_12000017() {
        // зЎ®дҝқжөӢиҜ•еүҚеҜҶй’ҘдёҚеӯҳеңЁ
        try {
            deleteKeyItem(TEST_KEY_ALIAS, HuksOptions())
        } catch (_) {
            // еҝҪз•ҘеҲ йҷӨдёҚеӯҳеңЁеҜҶй’Ҙзҡ„ејӮеёё
        }

        // е…ҲеҜје…ҘдёҖдёӘеҜҶй’Ҙ
        let keyData: Bytes = Array(16, { i => UInt8(i & 0xFF) })
        let options = HuksOptions(
            properties: [
                HuksParam(HuksTag.HUKS_TAG_ALGORITHM, HuksParamValue.Uint32Value(HuksKeyAlg.HUKS_ALG_AES)),
                HuksParam(HuksTag.HUKS_TAG_KEY_SIZE, HuksParamValue.Uint32Value(HuksKeySize.HUKS_AES_KEY_SIZE_128)),
                HuksParam(HuksTag.HUKS_TAG_PURPOSE, HuksParamValue.Uint32Value(
                    HuksKeyPurpose.HUKS_KEY_PURPOSE_ENCRYPT | HuksKeyPurpose.HUKS_KEY_PURPOSE_DECRYPT))
            ],
            inData: keyData
        )
        importKeyItem(TEST_KEY_ALIAS, options)

        try {
            // еҶҚж¬ЎеҜје…ҘеҗҢеҗҚеҜҶй’Ҙ
            importKeyItem(TEST_KEY_ALIAS, options)
            @Expect(true) // еә”иҜҘжү§иЎҢеҲ°иҝҷйҮҢ
        } catch (e: BusinessException) {
            @Expect(false)
        } finally {
            // жё…зҗҶпјҡеҲ йҷӨеҜје…Ҙзҡ„еҜҶй’Ҙ
            deleteKeyItem(TEST_KEY_ALIAS, HuksOptions())
        }
    }
}
